{
  "1": {
    "inputs": {
      "image": "input_image.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Reference Image" }
  },
  "2": {
    "inputs": {
      "ckpt_name": "sd_xl_base_1.0.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load SDXL Checkpoint" }
  },
  "3": {
    "inputs": {
      "text": "high quality, detailed, professional photo, same composition and style as reference",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "4": {
    "inputs": {
      "text": "low quality, blurry, distorted, watermark, text, logo",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "5": {
    "inputs": {
      "pixels": ["1", 0],
      "vae": ["2", 2]
    },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode" }
  },
  "6": {
    "inputs": {
      "seed": 0,
      "steps": 25,
      "cfg": 7,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 0.55,
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler (img2img)" }
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 2]
    },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "8": {
    "inputs": {
      "filename_prefix": "lulian_pseudo_original",
      "images": ["7", 0]
    },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Result" }
  }
}
